<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Happy Birthday Junaid!</title>
    <style>
        body {
            background-color: #ffe6e6;
            font-family: 'Arial', sans-serif;
            text-align: center;
            margin: 0;
            padding: 0;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            height: 100vh;
            overflow: hidden;
        }
        h1 {
            color: #ff4d4d;
            font-size: 2.5rem;
            margin-bottom: 10px;
        }
        p {
            color: #666;
            font-size: 1.2rem;
            margin-bottom: 30px;
        }
        /* Cake Styling */
        .cake-container {
            cursor: pointer;
            position: relative;
            transition: transform 0.3s;
        }
        .cake-container:hover {
            transform: scale(1.05);
        }
        .cake {
            width: 200px;
            height: 120px;
            background: #ff9999;
            border-radius: 20px 20px 0 0;
            position: relative;
            box-shadow: 0 10px 20px rgba(0,0,0,0.1);
        }
        .cake::before {
            content: "";
            position: absolute;
            width: 100%;
            height: 30px;
            background: #ff6666;
            border-radius: 20px 20px 0 0;
            top: 0;
            left: 0;
        }
        .cream {
            position: absolute;
            width: 200px;
            height: 20px;
            background: #ffffff;
            top: 25px;
            border-radius: 0 0 10px 10px;
        }
        .candle {
            width: 15px;
            height: 50px;
            background: #66ccff;
            position: absolute;
            top: -50px;
            left: 92px;
            border-radius: 5px 5px 0 0;
        }
        .flame {
            width: 15px;
            height: 25px;
            background: #ffcc00;
            border-radius: 50% 50% 50% 50% / 60% 60% 40% 40%;
            position: absolute;
            top: -75px;
            left: 92px;
            animation: flicker 0.5s infinite alternate;
        }
        @keyframes flicker {
            0% { transform: scale(1); opacity: 0.9; }
            100% { transform: scale(1.1); opacity: 1; }
        }
        .instruction {
            margin-top: 20px;
            font-weight: bold;
            color: #ff4d4d;
            animation: blink 1.5s infinite;
        }
        @keyframes blink {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.4; }
        }
    </style>
</head>
<body>

    <h1>Happy Birthday Sheikh Sahab! ✨</h1>
    <p>Apna birthday cake cut karne ke liye candle par touch karein...</p>

    <!-- Interactive Cake -->
    <div class="cake-container" onclick="nextPage()">
        <div class="flame" id="flame"></div>
        <div class="candle"></div>
        <div class="cake">
            <div class="cream"></div>
        </div>
    </div>

    <div class="instruction">🎂 Touch here to blow candle & cut the cake!</div>

    <script>
        function nextPage() {
            // Candle bhujne ka effect
            document.getElementById('flame').style.display = 'none';
            
            // 1 second ke baad video/surprise page par le kar jayega
            setTimeout(function() {
                window.location.href = "surprise.html";
            }, 1000);
        }
    </script>

</body>
</html>
